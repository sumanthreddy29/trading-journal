# Copy this to .env for local development

# Neon connection string (from Neon dashboard → Connection Details)
# For local dev, use a local Postgres URL:
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://localhost:5432/trading_journal

# CHANGE THIS to a long random string in production!
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-secret

# Server port (Render sets this automatically)
PORT=3000
